{
  "name": "netfusion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "test": "vitest run",
    "test:ai": "vitest run src/api/__tests__/verify_ai_frontend.ts",
    "test:knowledge": "vitest run src/api/__tests__/verify_knowledge_frontend.ts",
    "test:workflow": "vitest run src/api/__tests__/verify_workflow_frontend.ts",
    "check:ts": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@prisma/client": "^6.9.0",
    "@react-pdf/renderer": "^3.4.5",
    "@tiptap/extension-placeholder": "^3.24.0",
    "@tiptap/react": "^3.24.0",
    "@tiptap/starter-kit": "^3.24.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "groq-sdk": "^1.2.1",
    "mysql2": "^3.22.4",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.4.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^1.6.0"
  }
}
